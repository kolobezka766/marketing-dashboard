# Zkopíruj tento soubor jako .env.local a vyplň hodnoty
# NIKDY necommituj .env.local do gitu!

# ─── Google Ads ───────────────────────────────────────────────
# Jak získat: https://developers.google.com/google-ads/api/docs/first-call/overview
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=        # MCC nebo client account ID (bez pomlček)

# ─── Meta Marketing API ───────────────────────────────────────
# Jak získat: https://developers.facebook.com/docs/marketing-api/get-started
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=            # act_XXXXXXXXXX

# ─── TikTok Marketing API ─────────────────────────────────────
# Jak získat: https://business-api.tiktok.com/portal/docs
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=
